# Server
PORT=3000
HOST=0.0.0.0

# Proxy API key. Leave empty to allow unauthenticated requests.
API_KEY=

# Qwen credentials for automatic login/account rotation.
QWEN_EMAIL=
QWEN_PASSWORD=

# Set to 'true' to bypass account rotation and use only guest mode.
QWEN_GUEST_MODE_ONLY=false

# Qwen endpoints.
QWEN_BASE_URL=https://chat.qwen.ai
QWEN_HTTP_ENDPOINT=https://api.qwen.ai/v1/chat

# Performance: Use direct Node.js fetch instead of browser fetch (faster, less overhead)
# Set to 'false' to use browser-based fetch (needed for some anti-bot challenges)
DIRECT_FETCH=true

# ─── Speed Optimization (Vitesse Éclair) ─────────────────────────────────────
# Enable zero-copy SSE stream proxy (10-50x faster per chunk)
FAST_STREAM_PROXY=true

# TLS connection pool size for HTTP/2 multiplexing (eliminates TLS handshake overhead)
TLS_POOL_SIZE=5

# Use WebSocket in-page bridge instead of CDP (50-200x faster browser streaming)
USE_WS_BRIDGE=false

# Enable experimental HTTP/3 via QUIC (0-RTT connection resumption)
USE_HTTP3=false

# ─── Warm Pool Optimization ──────────────────────────────────────────────────
# Pool size (number of pre-created chat sessions)
WARM_POOL_SIZE=10

# Low water mark (trigger refill when below this)
WARM_POOL_LOW_WATER=3

# Parallel chat creation (create N chats simultaneously)
WARM_POOL_PARALLEL=3

# Delay between parallel batches (ms)
WARM_POOL_DELAY_MS=500

# Optional Qwen API key when using the HTTP endpoint.
QWEN_API_KEY=

# Browser configuration.
BROWSER=chromium
HEADLESS=true
USER_DATA_DIR=./qwen_profiles
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/137.0.0.0 Safari/537.36
LOG_CONSOLE=false

# Timeouts (milliseconds).
NAVIGATION_TIMEOUT=45000
PAGE_TIMEOUT=30000
HTTP_TIMEOUT=30000
HEADERS_TIMEOUT=60000
CHAT_TIMEOUT=120000
STREAM_IDLE_TIMEOUT=180000

# Cache TTL values (seconds).
CACHE_TTL=3600
RESPONSE_TTL=1800

# Metrics collection interval (milliseconds).
METRICS_INTERVAL=10000

# Watchdog settings.
WATCHDOG_INTERVAL=5000
WATCHDOG_FAILURES=3
RAM_WARNING=80
RAM_CRITICAL=95
WS_WARNING=50
WS_CRITICAL=100

# ─── Custom Model Mapping ────────────────────────────────────────────────────
# Path to the model mapping config file.
MODEL_MAPPING_FILE=./config/model-mapping.json

# Set to 'true' to disable automatic route generation.
DISABLE_AUTO_MAPPING=false

# ─── Request History & Logging ───────────────────────────────────────────────
# Enable request logging to SQLite.
REQUEST_LOG_ENABLED=true

# Path to the SQLite database for request logs.
REQUEST_LOG_DB=./data/requests.db

# Number of days to keep request logs.
REQUEST_LOG_RETENTION_DAYS=30

# ─── Redis (Optional) ────────────────────────────────────────────────────────
# Redis URL for shared state and caching (for serverless deployments).
# Supports standard Redis and Upstash REST.
REDIS_URL=
REDIS_TOKEN=

# ─── Debug Mode ──────────────────────────────────────────────────────────────
# Enable debug mode at startup (can be toggled at runtime via API/dashboard).
DEBUG_MODE=false

# Maximum number of debug log entries kept in memory.
DEBUG_BUFFER_SIZE=5000

# Persist debug mode state to disk (survives restarts).
DEBUG_PERSIST=false

# ─── Session Management (Multi-Tours) ────────────────────────────────────────
# Enable persistent chat sessions (preserves context across requests).
SESSION_ENABLED=true

# Session TTL in milliseconds (default: 30 minutes).
SESSION_TTL=1800000

# Maximum number of concurrent sessions (default: 200).
SESSION_MAX=200

# Auto-detect sessions by comparing message arrays (fallback when no header).
SESSION_AUTO_DETECT=true

# Header refresh interval in milliseconds (default: 3.5 minutes).
SESSION_HEADER_REFRESH=210000
